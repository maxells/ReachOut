# Copy this file to .env.local and fill in your API keys
# cp .env.local.example .env.local

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=

# Optional: override the default outreach pitch generation model
OPENAI_MODEL=gpt-5.4-mini

# Clod — creator scoring / ranking (JWT; used by `src/lib/clod.ts`)
CLOD_API_KEY=

# HeyReach — LinkedIn sends from Step 5 when channel is LinkedIn (server-side only).
# Create key under HeyReach Settings → API. Never expose via NEXT_PUBLIC_*.
HEYREACH_API_KEY=

# Optional: override API host (default https://api.heyreach.io/api/public)
# HEYREACH_API_BASE_URL=

# Optional: comma-separated HeyReach LinkedIn sender account id(s). If unset, the adapter uses linkedinAccount/GetAll (first connected account).
# HEYREACH_LINKEDIN_ACCOUNT_ID=

# mock = always mock send (including LinkedIn). auto (default) = use HeyReach when HEYREACH_API_KEY is set for LinkedIn.
OUTREACH_SEND_MODE=auto

# Optional: hours to wait on EACH sequence step (MESSAGE and END); HeyReach requires ≥3 per unconditional edge.
# HEYREACH_SEQUENCE_FIRST_DELAY_HOURS=3
