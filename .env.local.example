# Copy this file to .env.local and fill in your API keys
# cp .env.local.example .env.local

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-key-here

# CLōD.io API Key (required for Member 2: influencer matching)
# Get from: https://clod.io/dashboard
CLOD_API_KEY=your-clod-jwt-from-clod-io-dashboard

# Apify API Token (required for Member 2: LinkedIn scraping)
# Get from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxxxxxxx
